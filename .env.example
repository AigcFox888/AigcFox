# Default to the local production-like edge entrypoint.
# Override both URLs to http://localhost:3210 only when you intentionally run the raw FastAPI app directly.
AIGCFOX_API_BASE_URL=https://localhost:33443
AIGCFOX_PLATFORM_URL=https://localhost:33443
AIGCFOX_APP_ENV=development
AIGCFOX_AUTH_SECRET=change-me-before-production-2026
AIGCFOX_DEMO_EMAIL=operator@aigcfox.dev
AIGCFOX_DEMO_PASSWORD=AigcFox123!
AIGCFOX_DEMO_LICENSE_KEY=AIGCFOX-STAGE2
# Keep fixture as the default local auth mode. Database mode commands override this to
# `database`.
# Skill registry truth inherits the auth data source in local development unless you
# explicitly override `AIGCFOX_SKILL_DATA_SOURCE=database` for database-backed skill
# marketplace work.
# Staging / production must switch auth and Skill data sources to `database` and replace
# the default auth secret.
# This root template is for local development only.
# Release hosts should start from `config/backend/staging.env.example` or
# `config/backend/production.env.example`, prepared via
# `pnpm backend:prepare-release-env` and verified by
# `pnpm qa:backend-release-env-template`.
AIGCFOX_AUTH_DATA_SOURCE=fixture
AIGCFOX_SKILL_DATA_SOURCE=inherit
AIGCFOX_BOOTSTRAP_DEMO_RECORDS=true
# Default reboot entrypoint:
# `pnpm backend:https:up`
# `pnpm backend:https:verify`
# Only use the raw local-stack + direct FastAPI commands below when you intentionally
# need the HTTP / direct-process debug path:
# `pnpm backend:local-stack:up`
# `pnpm backend:prepare-local-env`
# `pnpm qa:backend-database-readiness`
# `pnpm qa:backend-queue-readiness`
# `pnpm backend:migrate:database`
# `pnpm dev:backend:database`
# `pnpm dev:backend-worker:database`
# `pnpm dev:backend-beat:database`
# If localhost:5432 / 6379 is occupied, start the local stack with
# `pnpm backend:local-stack:up -- --database-port=55432 --redis-port=56379`
# and rewrite the URLs below via `pnpm backend:prepare-local-env -- ...`.
AIGCFOX_DATABASE_URL=postgresql+psycopg://aigcfox:aigcfox@localhost:5432/aigcfox
# Replace Redis credentials / db indexes before queue readiness or Celery startup.
AIGCFOX_REDIS_URL=redis://localhost:6379/0
AIGCFOX_CELERY_BROKER_URL=redis://localhost:6379/1
AIGCFOX_CELERY_RESULT_BACKEND=redis://localhost:6379/2
